<p class="alert alert-danger js-hipay-payments-paypal-address-message" style="display: none;">
    <span data-error-type="generic" style="display: none">{l s='Invalid delivery address. Please check or correct your delivery address.' mod='hipaypayments'}</span>
    <span data-error-type="field" style="display: none">{l s='Invalid delivery address. Please check or correct the following fields:' mod='hipaypayments'}</span>
    <span class="error-streetaddress" style="display: none">{l s='Address' mod='hipaypayments'}</span>
    <span class="error-zipCode" style="display: none">{l s='Postcode' mod='hipaypayments'}</span>
    <span class="error-country" style="display: none">{l s='Country' mod='hipaypayments'}</span>
    <span class="error-city" style="display: none">{l s='City' mod='hipaypayments'}</span>
</p>
